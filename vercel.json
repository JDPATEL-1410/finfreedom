{
    "rewrites": [
        {
            "source": "/api/blog/latest",
            "destination": "/api/blog/latest.js"
        },
        {
            "source": "/api/contact/submit",
            "destination": "/api/contact/submit.js"
        },
        {
            "source": "/api/health",
            "destination": "/api/health.js"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}